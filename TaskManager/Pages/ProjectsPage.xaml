<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:TaskManager.Pages"
             xmlns:models="clr-namespace:TaskManager.UIModels.ProjectUIModels;assembly=TaskManager.UIModels"
             x:Class="TaskManager.Pages.ProjectsPage"
             x:DataType="pages:ProjectsPage"
             Title="Projects">
    <!-- List of all projects -->
    <CollectionView
        ItemsSource="{Binding Projects}"
        SelectionMode="Single"
        Margin="10"
        SelectionChanged="ProjectSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:ProjectDisplayModel">
                <Border
                    Stroke="{StaticResource BorderMedium}"
                    StrokeThickness="1"
                    Padding="15"
                    Margin="0,8"
                    BackgroundColor="{StaticResource ProjectCardBackground}">
                    <VerticalStackLayout Spacing="5">
                        <Label
                            Style="{StaticResource Headline}"
                            Text="{Binding Name}" />
                        <Grid ColumnDefinitions="*, *">
                            <Label Grid.Column="0"
                                   Style="{StaticResource SubHeadline}"
                                   Text="{Binding ProjectType}"
                                   HorizontalOptions="Start" />
                            <Label Grid.Column="1"
                                   Style="{StaticResource SubHeadline}"
                                   Text="{Binding ProgressDescription}"
                                   HorizontalOptions="End" />
                        </Grid>
                        <Label
                            TextColor="{StaticResource TextLighterPink}"
                            Text="{Binding Description}"
                            HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>