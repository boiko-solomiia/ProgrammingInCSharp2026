<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TaskManager.DTOModels.ProjectDTO;assembly=TaskManager.DTOModels"
             xmlns:vm="clr-namespace:TaskManager.ViewModels"
             x:Class="TaskManager.Pages.ProjectsPage"
             x:DataType="vm:ProjectsViewModel"
             x:Name="ProjectsPageRoot"
             Title="Projects">

<Grid RowDefinitions="*, Auto">
        <CollectionView x:Name="ProjectsCollection"
        Grid.Row="0"
        ItemsSource="{Binding Projects}"
        SelectionMode="Single"
        Margin="10"
        SelectedItem="{Binding SelectedProject}"
        SelectionChangedCommand="{Binding LoadProjectCommand}">

            <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:ProjectListDTO">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="#F6C1CC"
                                           Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.DeleteProjectCommand}"
                                           CommandParameter="{Binding .}" />
                                <SwipeItem Text="Edit"
                                           BackgroundColor="#C7DDF7"
                                           Command="{Binding Source={x:Reference ProjectsPageRoot}, Path=BindingContext.EditProjectCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border
                    Stroke="{StaticResource BorderMedium}"
                    StrokeThickness="1"
                    Padding="15"
                    Margin="0,8"
                    BackgroundColor="{StaticResource ProjectCardBackground}">
                    
                    <VerticalStackLayout Spacing="5">
                        <Label
                            Style="{StaticResource Headline}"
                            Text="{Binding Name}" />

                        <Label
                            TextColor="{StaticResource TextLighterPink}"
                            Text="{Binding TaskCountDescription}"
                            Style="{StaticResource Headline18}"
                            HorizontalOptions="Center" />
                        
                        <Grid ColumnDefinitions="*, *">
                            <Label Grid.Column="0"
                                   Style="{StaticResource SubHeadline}"
                                   Text="{Binding ProjectType}"
                                   HorizontalOptions="Start" />

                            <Label Grid.Column="1"
                                   Style="{StaticResource SubHeadline}"
                                   Text="{Binding ProgressDescription}"
                                   HorizontalOptions="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
              </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    
        <Button Grid.Row="1"
                Text="Add project"
                Command="{Binding AddProjectCommand}"
                HorizontalOptions="Center"
                Margin="10"
                WidthRequest="180" />

        <BoxView Grid.RowSpan="2"
                 IsVisible="{Binding IsBusy}"
                 BackgroundColor="Gray"
                 Opacity="0.2"
                 InputTransparent="False" />

        <ActivityIndicator Grid.RowSpan="2"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>