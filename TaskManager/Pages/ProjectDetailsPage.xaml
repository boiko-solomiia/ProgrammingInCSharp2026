<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:projectModels="clr-namespace:TaskManager.UIModels.ProjectUIModels;assembly=TaskManager.UIModels"
             xmlns:taskModels="clr-namespace:TaskManager.UIModels.TaskUIModels;assembly=TaskManager.UIModels"
             x:Class="TaskManager.Pages.ProjectDetailsPage"
             x:DataType="projectModels:ProjectDisplayModel"
             Title="Project Details">
    <Grid RowDefinitions="Auto, Auto, *"
          RowSpacing="3">
        <Border
            Grid.Row="0"
            Stroke="{StaticResource BorderMedium}"
            StrokeThickness="2"
            Padding="15"
            BackgroundColor="{StaticResource ProjectCardBackground}"
            Margin="10">
            <VerticalStackLayout Spacing="5">
                <Label
                    Style="{StaticResource Headline}"
                    Text="{Binding Name}" />
                <Grid ColumnDefinitions="*, *">
                    <Label Grid.Column="0"
                           Style="{StaticResource SubHeadline}"
                           Text="{Binding ProjectType}"
                           HorizontalOptions="Start" />
                    <Label Grid.Column="1"
                           Style="{StaticResource SubHeadline}"
                           Text="{Binding ProgressDescription}"
                           HorizontalOptions="End" />
                </Grid>
                <Label
                    Text="{Binding Description}"
                    TextColor="{StaticResource TextLighterPink}"
                    HorizontalOptions="Start"
                    FontSize="16" />
            </VerticalStackLayout>
        </Border>
        <Label Grid.Row="1"
               Text="Tasks"
               Style="{StaticResource Headline}"
               TextColor="{StaticResource TextBlue}"
               Margin="5" />
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Tasks}"
                        SelectionMode="Single"
                        SelectionChanged="TaskSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate
                    x:DataType="taskModels:TaskDisplayModel">
                    <Border
                        Stroke="{StaticResource Secondary}"
                        StrokeThickness="1"
                        Padding="12"
                        Margin="0,5">
                        <VerticalStackLayout>
                            <Label
                                Style="{StaticResource SubHeadline}"
                                Text="{Binding Name}" />
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Priority, StringFormat='Priority: {0}'}"
                                       TextColor="{StaticResource SecondaryDark}" />
                                <Label Grid.Column="1"
                                       Text="{Binding IsCompleted, StringFormat='Completed: {0}'}"
                                       TextColor="{StaticResource SecondaryDark}" />
                            </Grid>
                            <Label Text="{Binding Deadline, StringFormat='Due: {0:dd MMM yyyy}'}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>